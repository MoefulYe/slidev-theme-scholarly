    "prefix": ["scholarly-example-theorem", "ss-example-theorem"],
    "body": [
      "<Theorem type=\"example\">",
      "",
      "${1:Example content here.}",
      "",
      "</Theorem>",
      "",
      "$0"
    ],
    "description": "Insert Example theorem block"
  },
  "Slidev Scholarly: Note": {
    "prefix": ["scholarly-note", "ss-note"],
    "body": [
      "<Theorem type=\"note\">",
      "",
      "${1:Note content here.}",
      "",
      "</Theorem>",
      "",
      "$0"
    ],
    "description": "Insert Note theorem block"
  },
  "Slidev Scholarly: Theorem Compact": {
    "prefix": ["scholarly-theorem-compact", "ss-theorem-compact"],
    "body": [
      "<Theorem type=\"${1|theorem,lemma,definition|}\" :compact=\"true\">",
      "",
      "${2:Compact theorem content.}",
      "",
      "</Theorem>",
      "",
      "$0"
    ],
    "description": "Insert compact Theorem"
  },
  "Slidev Scholarly: Highlight (Vue)": {
    "prefix": ["scholarly-highlight", "ss-highlight"],
    "body": [
      "<Highlight type=\"${1|primary,success,warning,danger,info|}\">${2:highlighted text}</Highlight>$0"
    ],
    "description": "Insert Highlight component"
  },
  "Slidev Scholarly: Steps": {
    "prefix": ["scholarly-steps", "ss-steps"],
    "body": [
      "<Steps :steps=\"[",
      "  { title: '${1:Step 1}', description: '${2:Description 1}' },",
      "  { title: '${3:Step 2}', description: '${4:Description 2}' },",
      "  { title: '${5:Step 3}', description: '${6:Description 3}' }",
      "]\" :activeStep=\"${7:1}\" />",
      "",
      "$0"
    ],
    "description": "Insert Steps component"
  },
  "Slidev Scholarly: Columns": {
    "prefix": ["scholarly-columns", "ss-columns"],
    "body": [
      "<Columns :columns=\"${1:3}\" :gap=\"${2:2}\">",
      "",
      "${3:Column 1 content}",
      "",
      "---",
      "",
      "${4:Column 2 content}",
      "",
      "---",
      "",
      "${5:Column 3 content}",
      "",
      "</Columns>",
      "",
      "$0"
    ],
    "description": "Insert Columns component"
  },
  "Slidev Scholarly: Keywords": {
    "prefix": ["scholarly-keywords", "ss-keywords"],
    "body": [
      "<Keywords :keywords=\"['${1:Keyword 1}', '${2:Keyword 2}', '${3:Keyword 3}']\" />",
      "",
      "$0"
    ],
    "description": "Insert Keywords component"
  },
  "Slidev Scholarly: Citation Parenthetical": {
    "prefix": ["scholarly-cite", "ss-cite", "@cite"],
    "body": [
      "@${1:citekey}$0"
    ],
    "description": "Insert parenthetical citation (Author, Year)"
  },
  "Slidev Scholarly: Citation Narrative": {
    "prefix": ["scholarly-cite-narrative", "ss-cite-n", "!@cite"],
    "body": [
      "!@${1:citekey}$0"
    ],
    "description": "Insert narrative citation Author (Year)"
  },
  "Slidev Scholarly: Multiple Citations": {
    "prefix": ["scholarly-cite-multi", "ss-cite-multi"],
    "body": [
      "@${1:citekey1} @${2:citekey2}$0"
    ],
    "description": "Insert multiple citations"
  },
  "Slidev Scholarly: Bibliography Marker": {
    "prefix": ["scholarly-bibliography", "ss-bibliography"],
    "body": [
      "[[bibliography]]",
      "",
      "$0"
    ],
    "description": "Insert bibliography marker"
  },
  "Slidev Scholarly: Math Inline": {
    "prefix": ["scholarly-math-inline", "ss-math-i"],
    "body": [
      "\\$${1:formula}\\$$0"
    ],
    "description": "Insert inline math"
  },
  "Slidev Scholarly: Math Block": {
    "prefix": ["scholarly-math-block", "ss-math-b"],
    "body": [
      "",
      "\\$\\$${1:formula}\\$\\$",
      "",
      "$0"
    ],
    "description": "Insert math block"
  },
  "Slidev Scholarly: Font Size Config": {
    "prefix": ["scholarly-fontsize", "ss-fontsize"],
    "body": [
      "fontsize:",
      "  body: ${1:18px}",
      "  h1: ${2:42px}",
      "  h2: ${3:32px}",
      "  h3: ${4:24px}"
    ],
    "description": "Insert font size configuration"
  },
  "Slidev Scholarly: Slide Comment": {
    "prefix": ["scholarly-comment", "ss-comment"],
    "body": [
      "<!--",
      "SLIDE: ${1:Slide Name}",
      "LAYOUT: ${2:layout}",
      "PURPOSE: ${3:Description}",
      "-->"
    ],
    "description": "Insert slide documentation comment"
  }
}
