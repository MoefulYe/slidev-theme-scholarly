{
  "Slidev Scholarly: Block (Vue)": {
    "prefix": ["scholarly-block", "ss-block"],
    "body": [
      "<Block type=\"${1|info,default,success,warning,danger,example|}\" title=\"${2:Block Title}\">",
      "",
      "${3:Block content goes here.}",
      "",
      "</Block>",
      "",
      "$0"
    ],
    "description": "Insert Block component (Vue syntax)"
  },
  "Slidev Scholarly: Block (Syntax Sugar)": {
    "prefix": ["scholarly-block-md", "ss-block-md"],
    "body": [
      ":::block{type=\"${1|info,default,success,warning,danger,example|}\" title=\"${2:Block Title}\"}",
      "${3:Block content goes here.}",
      ":::",
      "",
      "$0"
    ],
    "description": "Insert Block component (Markdown syntax sugar)"
  },
  "Slidev Scholarly: Theorem (Vue)": {
    "prefix": ["scholarly-theorem", "ss-theorem"],
    "body": [
      "<Theorem type=\"${1|theorem,lemma,definition,corollary,claim,example,proof,note|}\" title=\"${2:Theorem Name}\">",
      "",
      "${3:Mathematical statement here.}",
      "",
      "</Theorem>",
      "",
      "$0"
    ],
    "description": "Insert Theorem component (Vue syntax)"
  },
  "Slidev Scholarly: Theorem (Syntax Sugar)": {
    "prefix": ["scholarly-theorem-md", "ss-theorem-md"],
    "body": [
      ":::theorem{type=\"${1|theorem,lemma,definition,corollary,claim,example,proof,note|}\" title=\"${2:Theorem Name}\"}",
      "${3:Mathematical statement here.}",
      ":::",
      "",
      "$0"
    ],
    "description": "Insert Theorem component (Markdown syntax sugar)"
  },
