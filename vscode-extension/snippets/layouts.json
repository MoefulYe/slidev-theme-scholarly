    ],
    "body": [
      "---",
      "layout: statement",
      "---",
      "",
      "# ${1:Your Statement}",
      "",
      "${2:Supporting text.}",
      "",
      "$0"
    ],
    "description": "[Emphasis] Bold statement"
  },
  "Slidev Scholarly: Focus Layout": {
    "prefix": [
      "scholarly-focus",
      "ss-focus",
      "ss-emphasis-focus"
    ],
    "body": [
      "---",
      "layout: focus",
      "color: ${1|primary,blue,green,amber,red,purple|}",
      "icon: ${2:\ud83c\udfaf}",
      "---",
      "",
      "# ${3:Main Message}",
      "",
      "${4:Supporting text.}",
      "",
      "$0"
    ],
    "description": "[Emphasis] Focused message with icon"
  },

  "_comment_academic": "=== ACADEMIC LAYOUTS ===",
  "Slidev Scholarly: Compare Layout": {
    "prefix": [
      "scholarly-compare",
      "ss-compare",
      "ss-academic-compare"
    ],
    "body": [
      "---",
      "layout: compare",
      "title: ${1:Comparison}",
      "leftLabel: ${2:Option A}",
      "rightLabel: ${3:Option B}",
      "leftColor: ${4|red,blue,green,gray|}",
      "rightColor: ${5|green,blue,red,gray|}",
      "---",
      "",
      "### ${6:Option A Points}",
      "",
      "- ${7:Point 1}",
      "- ${8:Point 2}",
      "",
      "::right::",
      "",
      "### ${9:Option B Points}",
      "",
      "- ${10:Point 1}",
      "- ${11:Point 2}",
      "",
      "$0"
    ],
    "description": "[Academic] Side-by-side comparison"
  },
  "Slidev Scholarly: Methodology Layout": {
    "prefix": [
      "scholarly-methodology",
      "ss-methodology",
      "ss-academic-methodology"
    ],
    "body": [
      "---",
      "layout: methodology",
      "ratio: \"${1|1:1,2:1,1:2|}\"",
      "title: ${2:Methodology}",
      "---",
      "",
      "## ${3:Our Approach}",
      "",
      "${4:Method description}",
      "",
      "::right::",
      "",
      "${5:Diagram or visual}",
      "",
      "$0"
    ],
    "description": "[Academic] Research methodology"
  },
  "Slidev Scholarly: Results Layout": {
    "prefix": [
      "scholarly-results",
      "ss-results",
      "ss-academic-results"
    ],
    "body": [
      "---",
      "layout: results",
      "cols: ${1|2,3,4|}",
      "title: ${2:Key Results}",
      "---",
      "",
      "<div class=\"p-4 bg-white rounded shadow\">",
      "  <h3>${3:Metric 1}</h3>",
      "  <h1>${4:Value}</h1>",
      "</div>",
      "",
      "<div class=\"p-4 bg-white rounded shadow\">",
      "  <h3>${5:Metric 2}</h3>",
      "  <h1>${6:Value}</h1>",
      "</div>",
      "",
      "$0"
    ],
    "description": "[Academic] Results dashboard"
  },
  "Slidev Scholarly: Timeline Layout": {
    "prefix": [
      "scholarly-timeline",
      "ss-timeline",
      "ss-academic-timeline"
    ],
    "body": [
      "---",
      "layout: timeline",
      "title: ${1:Timeline Title}",
      "items:",
      "  - year: \"${2:2020}\"",
      "    title: ${3:First Event}",
      "    description: ${4:Description}",
      "  - year: \"${5:2021}\"",
      "    title: ${6:Second Event}",
      "    description: ${7:Description}",
      "---",
      "",
      "$0"
    ],
    "description": "[Academic] Research timeline"
  },
  "Slidev Scholarly: Agenda Layout": {
    "prefix": [
      "scholarly-agenda",
      "ss-agenda",
      "ss-academic-agenda"
    ],
    "body": [
      "---",
      "layout: agenda",
      "title: ${1:Today's Agenda}",
      "items:",
      "  - ${2:Introduction}",
      "  - ${3:Main Topic}",
      "  - ${4:Discussion}",
      "  - ${5:Q&A}",
      "---",
      "",
      "$0"
    ],
    "description": "[Academic] Agenda/overview"
  },
  "Slidev Scholarly: Acknowledgments Layout": {
    "prefix": [
      "scholarly-acknowledgments",
      "ss-acknowledgments",
      "ss-academic-acknowledgments"
    ],
    "body": [
