  "_comment_utility": "=== UTILITY ===",
  "Slidev Scholarly: Slide Divider": {
    "prefix": [
      "scholarly-slide",
      "ss-slide",
      "---"
    ],
    "body": [
      "---",
      "",
      "$0"
    ],
    "description": "Insert slide divider"
  },
  "Slidev Scholarly: Frontmatter": {
    "prefix": [
      "scholarly-frontmatter",
      "ss-frontmatter"
    ],
    "body": [
      "---",
      "theme: scholarly",
      "footerMiddle: ${1:Conference Name}",
      "lang: ${2|en,zh|}",
      "themeConfig:",
      "  colorTheme: ${3|classic-blue,oxford-burgundy,cambridge-green,yale-blue,princeton-orange,monochrome,warm-sepia,nordic-blue,high-contrast|}",
      "  fontTheme: ${4|classic,modern,traditional,contemporary,humanist,technical,elegant,sans-default|}",
      "  sectionMode: ${5|dark,light|}",
      "bibFile: ./references.bib",
      "bibStyle: ${6|apa,harvard1,vancouver,ieee,mla,chicago-author-date|}",
      "authors:",
      "  - name: ${7:Author Name}",
      "    institution: ${8:Institution}",
      "    email: ${9:email@example.com}",
      "---",
      "",
      "# ${10:Presentation Title}",
      "",
      "${11:Subtitle}",
      "",
      "$0"
    ],
    "description": "Full frontmatter with theme configuration"
  },

