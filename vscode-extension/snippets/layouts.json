      "",
      "$0"
    ],
    "description": "Insert references layout"
  },
  "Slidev Scholarly: End Layout": {
    "prefix": ["scholarly-end", "ss-end"],
    "body": [
      "---",
      "layout: end",
      "email: ${1:your@email.com}",
      "website: ${2:https://example.com}",
      "subtitle: ${3:Questions?}",
      "---",
      "",
      "${4:Thank you for your attention!}",
      "",
      "$0"
    ],
    "description": "Insert end layout"
  },
  "Slidev Scholarly: Intro Layout": {
    "prefix": ["scholarly-intro", "ss-intro"],
    "body": [
      "---",
      "layout: intro",
      "---",
      "",
      "# ${1:Introduction Title}",
      "",
      "${2:Introduction content.}",
      "",
      "$0"
    ],
    "description": "Insert intro layout"
  },
  "Slidev Scholarly: Slide Divider": {
    "prefix": ["scholarly-slide", "ss-slide", "---"],
    "body": [
      "---",
      "",
      "$0"
    ],
    "description": "Insert slide divider"
  },
  "Slidev Scholarly: Frontmatter": {
    "prefix": ["scholarly-frontmatter", "ss-frontmatter"],
    "body": [
      "---",
      "theme: scholarly",
      "footerMiddle: ${1:Conference Name}",
      "lang: ${2|en,zh|}",
      "bibFile: ./references.bib",
      "bibStyle: ${3|apa,harvard1,vancouver,ieee,mla,chicago-author-date|}",
      "authors:",
      "  - name: ${4:Author Name}",
      "    institution: ${5:Institution}",
      "    email: ${6:email@example.com}",
      "---",
      "",
      "# ${7:Presentation Title}",
      "",
      "${8:Subtitle}",
      "",
      "$0"
    ],
    "description": "Insert full frontmatter configuration"
  }
}
