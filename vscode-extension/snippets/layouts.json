      "layout: acknowledgments",
      "title: ${1:Acknowledgments}",
      "funders:",
      "  - ${2:Funding Organization}",
      "collaborators:",
      "  - ${3:Collaborator Name}",
      "---",
      "",
      "${4:Additional thanks}",
      "",
      "$0"
    ],
    "description": "[Academic] Acknowledgments slide"
  },
  "Slidev Scholarly: References Layout": {
    "prefix": [
      "scholarly-references",
      "ss-references",
      "ss-academic-references"
    ],
    "body": [
      "---",
      "layout: references",
      "---",
      "",
      "[[bibliography]]",
      "",
      "$0"
    ],
    "description": "[Academic] Bibliography/References"
  },
  "Slidev Scholarly: TOC Layout": {
    "prefix": [
      "scholarly-toc",
      "ss-toc",
      "ss-academic-toc"
    ],
    "body": [
      "---",
      "layout: toc",
      "title: ${1:Outline}",
      "---",
      "",
      "$0"
    ],
