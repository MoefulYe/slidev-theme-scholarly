{
  "_comment_structure": "=== STRUCTURE LAYOUTS ===",
  "Slidev Scholarly: Cover Layout": {
    "prefix": [
      "scholarly-cover",
      "ss-cover",
      "ss-structure-cover"
    ],
    "body": [
      "---",
      "layout: cover",
      "---",
      "",
      "# ${1:Presentation Title}",
      "",
      "${2:Subtitle}",
      "",
      "$0"
    ],
    "description": "[Structure] Title slide for your presentation"
  },
  "Slidev Scholarly: Default Layout": {
    "prefix": [
      "scholarly-default",
      "ss-default",
      "ss-structure-default"
    ],
    "body": [
      "---",
      "layout: default",
      "title: ${1:Slide Title}",
      "subtitle: ${2:Optional subtitle}",
      "---",
      "",
      "## ${3:Content Title}",
      "",
      "${4:Your content here.}",
      "",
      "$0"
    ],
    "description": "[Structure] Standard content slide"
  },
  "Slidev Scholarly: Intro Layout": {
    "prefix": [
      "scholarly-intro",
      "ss-intro",
      "ss-structure-intro"
    ],
    "body": [
      "---",
      "layout: intro",
      "---",
      "",
      "# ${1:Introduction Title}",
      "",
      "${2:Introduction content.}",
      "",
      "$0"
    ],
    "description": "[Structure] Introduction slide"
  },
  "Slidev Scholarly: Section Layout": {
    "prefix": [
      "scholarly-section",
      "ss-section",
      "ss-structure-section"
    ],
    "body": [
      "---",
      "layout: section",
      "sectionMode: ${1|dark,light|}",
      "---",
      "",
      "# ${2:Section Title}",
      "",
      "${3:Section subtitle}",
      "",
      "$0"
    ],
    "description": "[Structure] Section divider (sectionMode: dark/light)"
  },
  "Slidev Scholarly: Center Layout": {
    "prefix": [
      "scholarly-center",
      "ss-center",
      "ss-structure-center"
    ],
    "body": [
      "---",
      "layout: center",
      "---",
      "",
      "## ${1:Centered Title}",
      "",
      "${2:Centered content}",
      "",
      "$0"
    ],
    "description": "[Structure] Centered content"
  },
  "Slidev Scholarly: Auto Center Layout": {
    "prefix": [
      "scholarly-auto-center",
      "ss-auto-center",
      "ss-structure-auto-center"
    ],
    "body": [
      "---",
      "layout: auto-center",
      "title: ${1:Title}",
      "subtitle: ${2:Subtitle}",
      "---",
      "",
      "## ${3:Auto-Centered Content}",
      "",
      "${4:Content with auto-adjusting font size.}",
      "",
      "$0"
    ],
    "description": "[Structure] Auto-adjusting centered content"
  },
  "Slidev Scholarly: End Layout": {
    "prefix": [
      "scholarly-end",
      "ss-end",
      "ss-structure-end"
    ],
    "body": [
      "---",
      "layout: end",
      "email: ${1:your@email.com}",
      "website: ${2:https://example.com}",
      "subtitle: ${3:Questions?}",
      "---",
      "",
      "${4:Thank you for your attention!}",
      "",
      "$0"
    ],
    "description": "[Structure] Closing slide with contact info"
  },

  "_comment_content": "=== CONTENT LAYOUTS ===",
  "Slidev Scholarly: Two Columns Layout": {
    "prefix": [
      "scholarly-two-cols",
      "ss-two-cols",
      "ss-content-two-cols"
    ],
    "body": [
      "---",
      "layout: two-cols",
      "ratio: \"${1|1:1,2:3,3:2,1:2,2:1|}\"",
      "title: ${2:Two Columns}",
      "---",
      "",
      "## ${3:Left Column}",
      "",
      "${4:Left content}",
      "",
      "::right::",
      "",
      "## ${5:Right Column}",
      "",
      "${6:Right content}",
      "",
      "$0"
    ],
    "description": "[Content] Two column layout"
  },
  "Slidev Scholarly: Image Left Layout": {
    "prefix": [
      "scholarly-image-left",
      "ss-image-left",
      "ss-content-image-left"
    ],
    "body": [
      "---",
      "layout: image-left",
      "image: ${1:https://example.com/image.jpg}",
      "ratio: \"${2|1:2,1:1,1:3|}\"",
      "title: ${3:Image Left}",
      "---",
      "",
      "## ${4:Content Title}",
      "",
      "${5:Your content on the right side.}",
      "",
      "$0"
    ],
    "description": "[Content] Image on left, content on right"
  },
  "Slidev Scholarly: Image Right Layout": {
    "prefix": [
      "scholarly-image-right",
      "ss-image-right",
      "ss-content-image-right"
    ],
    "body": [
      "---",
      "layout: image-right",
      "image: ${1:https://example.com/image.jpg}",
      "ratio: \"${2|2:1,1:1,3:1|}\"",
      "title: ${3:Image Right}",
      "---",
      "",
      "## ${4:Content Title}",
      "",
      "${5:Your content on the left side.}",
      "",
      "$0"
    ],
    "description": "[Content] Content on left, image on right"
  },
  "Slidev Scholarly: Bullets Layout": {
    "prefix": [
      "scholarly-bullets",
      "ss-bullets",
      "ss-content-bullets"
    ],
    "body": [
      "---",
      "layout: bullets",
      "title: ${1:Bullet Points}",
      "subtitle: ${2:Key points}",
      "icon: \"${3:\u25b8}\"",
      "---",
      "",
      "## ${4:Main Topic}",
      "",
      "- ${5:First point}",
      "- ${6:Second point}",
      "- ${7:Third point}",
      "",
      "$0"
    ],
    "description": "[Content] Bullet point list with customizable icon"
  },
  "Slidev Scholarly: Figure Layout": {
    "prefix": [
      "scholarly-figure",
      "ss-figure",
      "ss-content-figure"
    ],
    "body": [
      "---",
      "layout: figure",
      "src: ${1:https://example.com/figure.jpg}",
      "caption: ${2:Figure caption.}",
      "label: \"${3:Figure 1:}\"",
      "title: ${4:Figure Title}",
      "---",
      "",
      "${5:Additional description.}",
      "",
      "$0"
    ],
    "description": "[Content] Image with academic caption"
  },
  "Slidev Scholarly: Split Image Layout": {
    "prefix": [
      "scholarly-split-image",
      "ss-split-image",
      "ss-content-split-image"
    ],
    "body": [
      "---",
      "layout: split-image",
      "images:",
      "  - ${1:./image1.png}",
      "  - ${2:./image2.png}",
      "captions:",
      "  - ${3:Caption 1}",
      "  - ${4:Caption 2}",
      "title: ${5:Comparison}",
      "---",
      "",
      "$0"
    ],
    "description": "[Content] Side-by-side image comparison"
  },

  "_comment_emphasis": "=== EMPHASIS LAYOUTS ===",
  "Slidev Scholarly: Quote Layout": {
    "prefix": [
      "scholarly-quote",
      "ss-quote",
      "ss-emphasis-quote"
    ],
    "body": [
      "---",
      "layout: quote",
      "author: ${1:Author Name}",
      "source: ${2:Source, Year}",
      "---",
      "",
      "${3:Your inspiring quote goes here.}",
      "",
      "$0"
    ],
    "description": "[Emphasis] Quote with author attribution"
  },
  "Slidev Scholarly: Fact Layout": {
    "prefix": [
      "scholarly-fact",
      "ss-fact",
      "ss-emphasis-fact"
    ],
    "body": [
      "---",
      "layout: fact",
      "color: ${1|primary,blue,green,amber,red,purple|}",
      "---",
      "",
      "# ${2:99%}",
      "",
      "${3:Description of the statistic}",
      "",
      "$0"
    ],
    "description": "[Emphasis] Single statistic or fact"
  },
  "Slidev Scholarly: Statement Layout": {
    "prefix": [
      "scholarly-statement",
      "ss-statement",
