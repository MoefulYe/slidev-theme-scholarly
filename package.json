{
  "name": "slidev-theme-scholarly",
  "version": "0.3.1",
  "type": "module",
  "description": "A scholarly presentation theme for Slidev with LaTeX Beamer-style styling",
  "author": "Jiaxin Peng",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jxpeng98/slidev-theme-scholarly.git"
  },
  "bugs": {
    "url": "https://github.com/jxpeng98/slidev-theme-scholarly/issues"
  },
  "homepage": "https://github.com/jxpeng98/slidev-theme-scholarly#readme",
  "keywords": [
    "slidev-theme",
    "slidev",
    "scholarly",
    "academic",
    "presentation",
    "beamer",
    "latex"
  ],
  "files": [
    "components",
    "layouts",
    "styles",
    "setup",
    "utils",
    "vite.config.ts",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "slidev example.md --open",
    "build": "slidev build example.md",
    "export": "slidev export example.md",
    "screenshot": "slidev export example.md --format png",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:serve": "vitepress serve docs",
    "version:sync": "bun -e \"const fs=require('fs');const pkg=require('./package.json');const ext=require('./vscode-extension/package.json');ext.version=pkg.version;fs.writeFileSync('./vscode-extension/package.json',JSON.stringify(ext,null,2)+'\\n');\"",
    "bump:patch": "bun pm version patch && bun run version:sync",
    "bump:minor": "bun pm version minor && bun run version:sync",
    "bump:major": "bun pm version major && bun run version:sync",
    "tag": "git tag v$(bun -e \"console.log(require('./package.json').version)\")",
    "tag:push": "git push && git push origin v$(bun -e \"console.log(require('./package.json').version)\")",
    "release": "bun run version:sync && git add -A && git commit -m \"chore: release v$(bun -e \"console.log(require('./package.json').version\")\" && bun run tag && bun run tag:push",
    "vscode:package": "cd vscode-extension && bun run package",
    "vscode:release": "bun run version:sync && bun run vscode:package"
  },
  "dependencies": {
    "@jxpeng98/markdown-it-citation": "1.2.1",
    "@slidev/client": "^52.9.1",
    "@slidev/types": "^52.9.1"
  },
  "devDependencies": {
    "@slidev/cli": "^52.9.1",
    "vitepress": "2.0.0-alpha.12"
  },
  "//": "Learn more: https://sli.dev/guide/write-theme.html",
  "slidev": {
    "colorSchema": "both",
    "defaults": {
      "aspectRatio": "4:3",
      "fonts": {
        "sans": "Inter",
        "serif": "Merriweather",
        "mono": "JetBrains Mono"
      }
    },
    "themeConfig": {
      "author": "Your Name",
      "conference": "Your Conference"
    }
  }
}
